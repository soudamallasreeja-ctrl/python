Name = input("Enter name: ")
Gender = input("Enter gender (M/F): ")
Age = int(input("Enter age: "))

if Age < 18:
    print("Not Eligible")

elif Age > 60:
    print("Eligible")

elif Age > 18 and Gender == "F":
    print("{} has right to vote".format(Name))

elif Age > 30 and Gender == "M":
    print("{} has right to vote".format(Name))

else:
    print("{} has no right to vote".format(Name))
